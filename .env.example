# Путь к JSON-ключу сервисного аккаунта (имя файла в корне проекта или абсолютный путь)
CREDENTIALS_PATH=my-zerocoder-project-da0be47bed0c.json

# ID таблицы Google Sheets (из URL: /d/<SPREADSHEET_ID>/edit)
SPREADSHEET_ID=1aVBJJ8EGxfXVVaE-BT2I3ZfZkH79OUOD

# Путь к OAuth2 client secret JSON (личный аккаунт Google)
CREDENTIALS_CLIENT_PATH=client_secret.json

# ID папки Google Drive для отчётов и новых файлов
REPORT_FOLDER_ID=PUT_YOUR_FOLDER_ID_HERE

# Уровень логов: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Путь к файлу SQLite (локально относительно корня проекта; в Docker задаётся compose)
CRM_DB_PATH=data/crm.sqlite3

# Разрешить POST /admin/clear-database и /admin/seed-test-data (только для dev/Docker)
CRM_ALLOW_ADMIN_ENDPOINTS=false

# Для Docker: примонтированный каталог secrets (необязательно, см. docker-compose)
# CREDENTIALS_PATH=/app/secrets/service-account.json
# CREDENTIALS_CLIENT_PATH=/app/secrets/client_secret.json

# Токен OAuth Drive (после первого входа). В Docker — смонтируйте файл или задайте абсолютный путь
# TOKEN_PATH=token_drive.json
