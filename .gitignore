# ─── Секреты и локальная конфигурация (не выкладывать на GitHub) ───
.env
.env.*
!.env.example

# Каталог для ключей в Docker (docker-compose монтирует ./secrets)
secrets/

# OAuth Drive: сохранённый токен пользователя
token_drive.json
token.json

# OAuth-клиент Google (часто client_secret….json или …apps.googleusercontent.com.json)
client_secret*.json
*client_secret*.json
*apps.googleusercontent.com.json

# В корне репозитория JSON почти всегда — ключ сервисного аккаунта или client secret.
# Если понадобится закоммитить иной *.json в корень, перенесите его в подкаталог
# или выполните: git add -f имяфайла.json
/*.json

# Локальная база CRM и журналы SQLite
data/*.sqlite3
data/*.sqlite3-journal
data/*.sqlite3-wal
data/*.sqlite3-shm

# ─── Python ───
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.venv/
venv/
ENV/
.envrc

# ─── IDE / ОС ───
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Прочее ───
*.log
